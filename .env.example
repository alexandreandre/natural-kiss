# Modèle de configuration pour l'export Slack (scripts/slack_export.py + slack-pull)
# Copie ce fichier en .env (à la racine du repo) et remplis SLACK_TOKEN.
# ⚠️ Ne JAMAIS commiter .env ni coller ton token ailleurs (chat, issue, etc.).

# Token Slack — commence par xoxp- (token utilisateur) ou xoxb- (token bot).
# Voir scripts/README.md, section 1, pour l'obtenir.
SLACK_TOKEN=xoxp-...

# Canal à exporter (déjà pré-rempli pour ce projet : #ia-fruits-et-légumes).
# Pour un autre canal : ./scripts/slack-pull --list  puis colle l'ID ici.
SLACK_CHANNEL=C0BEBF3E2TG

# Optionnel — dossier de sortie (défaut : tmp/slack)
SLACK_EXPORT_DIR=tmp/slack
