#!/usr/bin/env bash
#
# slack-pull — exporte le canal Slack du projet dans tmp/slack/.
#
# Fonctionne pour n'importe qui sur ce repo : le venv Python et les
# dépendances sont créés automatiquement au premier lancement.
# Chaque personne met son propre token Slack dans .env (voir scripts/README.md).
#
#   ./scripts/slack-pull            # exporte le canal (SLACK_CHANNEL de .env)
#   ./scripts/slack-pull --list     # liste les canaux visibles avec ton token
#
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV="$ROOT/scripts/.venv"
PY="$VENV/bin/python"

if ! command -v python3 >/dev/null 2>&1; then
  echo "❌ python3 est requis mais introuvable. Installe Python 3, puis relance." >&2
  exit 1
fi

if [ ! -f "$ROOT/.env" ]; then
  echo "❌ Fichier .env manquant à la racine du repo." >&2
  echo "   1) cp .env.example .env" >&2
  echo "   2) colle ton token Slack dans SLACK_TOKEN (voir scripts/README.md, section 1)." >&2
  exit 1
fi

# Bootstrap du venv + dépendances (une seule fois, ~15 s).
if [ ! -x "$PY" ]; then
  echo "⏳ Première utilisation : installation de l'environnement Python…"
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q -r "$ROOT/scripts/requirements.txt"
fi

cd "$ROOT"
exec "$PY" scripts/slack_export.py "$@"
