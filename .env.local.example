# ─────────────────────────────────────────────────────────────────────────────
# Natural Kiss — configuration locale. Copiez ce fichier vers `.env.local`.
#   cp .env.local.example .env.local
# `.env.local` n'est JAMAIS versionné (cf. .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# CLOUD (dev/prod) : récupérez ces valeurs dans le dashboard de votre projet
#   Project Settings → API : Project URL, anon (public) key, service_role (secret) key.
#   ⚠️ La service role key est un SECRET serveur — ne l'exposez jamais côté client.
#
# LOCAL (tests) : valeurs affichées par `supabase start` / `supabase status`
#   (URL http://127.0.0.1:54321 + clés de démo locales bien connues).

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# ── Feature flags (surcharge des valeurs par défaut) ─────────────────────────
# true / false. En Brique 0, seul le référentiel est actif.
# NEXT_PUBLIC_FLAG_REFERENTIEL=true
# NEXT_PUBLIC_FLAG_TRACKING=false
# NEXT_PUBLIC_FLAG_GATE=false

# ── Adaptateurs externes (mock-first) ────────────────────────────────────────
# Laisser vide = mock. `real` = implémentation réelle (à brancher plus tard).
# NK_TRACKING_PROVIDER=mock      # MarineTraffic / FlightRadar
# NK_SENSOR_PROVIDER=mock        # datalogger / API capteurs
# NK_FIELDTRACE_PROVIDER=mock    # Cropwise
# NK_EMAIL_PROVIDER=mock         # boîte mail
# NK_LLM_PROVIDER=mock           # LLM
